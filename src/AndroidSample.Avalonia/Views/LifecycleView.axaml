<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AndroidSample.Avalonia.Views.LifecycleView">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="1. 应用生命周期" FontSize="20" FontWeight="Bold"/>
            <Button Content="← 返回" Click="OnBack"/>
            <TextBlock Text="操作：将应用切换到后台再回前台，观察事件日志。"
                       TextWrapping="Wrap" Foreground="Gray"/>
        </StackPanel>

        <ScrollViewer>
            <TextBlock x:Name="LogText" TextWrapping="Wrap" Margin="0,8,0,0"
                       FontFamily="Monospace"/>
        </ScrollViewer>
    </DockPanel>
</UserControl>
