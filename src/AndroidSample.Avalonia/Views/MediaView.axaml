<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AndroidSample.Avalonia.Views.MediaView">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="6. 多媒体（相机/相册）" FontSize="20" FontWeight="Bold"/>
            <Button Content="← 返回" Click="OnBack"/>
        </StackPanel>

        <StackPanel Spacing="12">
            <Button Content="📷 拍照" Click="OnTakePhoto" HorizontalAlignment="Stretch"/>
            <Button Content="🖼 从相册选图" Click="OnPickGallery" HorizontalAlignment="Stretch"/>
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="Gray"/>
            <Image x:Name="PreviewImage" MaxHeight="300" Stretch="Uniform"/>
        </StackPanel>
    </DockPanel>
</UserControl>
