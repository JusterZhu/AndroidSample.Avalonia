<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AndroidSample.Avalonia.Views.SensorView">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="4. 传感器" FontSize="20" FontWeight="Bold"/>
            <Button Content="← 返回" Click="OnBack"/>
        </StackPanel>

        <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnStart" Content="启动传感器" Click="OnStart"/>
                <Button x:Name="BtnStop"  Content="停止传感器" Click="OnStop" IsEnabled="False"/>
            </StackPanel>

            <TextBlock Text="加速度计 (m/s²)：" FontWeight="Bold"/>
            <TextBlock x:Name="AccelText" FontFamily="Monospace"/>

            <TextBlock Text="陀螺仪 (rad/s)：" FontWeight="Bold"/>
            <TextBlock x:Name="GyroText" FontFamily="Monospace"/>

            <Border Height="2" Background="Gray"/>

            <TextBlock x:Name="ShakeText" FontSize="16" Foreground="#C62828"/>
        </StackPanel>
    </DockPanel>
</UserControl>
